    <mxCell id="feed" value="q&#160;&#160; A&lt;sub&gt;f&lt;/sub&gt;&#160;&#160; T&lt;sub&gt;f&lt;/sub&gt;" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=classic;endFill=1;strokeColor=#000000;strokeWidth=2;fontSize=14;verticalAlign=bottom;labelBackgroundColor=#ffffff;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
