    <mxCell id="inner" value="&lt;b&gt;CSTR&lt;/b&gt;&lt;br&gt;V&lt;br&gt;A, T&lt;br&gt;A &#8594; B, exothermic" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="414" y="240" width="170" height="70" as="geometry"/>
    </mxCell>

    <mxCell id="adnote" value="&lt;b&gt;Adiabatic&lt;/b&gt; &#8212; no jacket, no coil, no condenser.&#10;The manipulated variable is the feed temperature T&lt;sub&gt;f&lt;/sub&gt;, but the paper&#10;models &lt;b&gt;no preheater&lt;/b&gt;: it only assumes the feed-temperature dynamics&#10;are much faster than the reactor dynamics. No upstream exchanger is drawn." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#333333;strokeColor=#cccccc;fillColor=#f7f7f7;spacing=8;" vertex="1" parent="1">
      <mxGeometry x="680" y="240" width="390" height="86" as="geometry"/>
    </mxCell>
    <mxCell id="adlead" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#999999;strokeWidth=1;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="624" y="290" as="sourcePoint"/>
        <mxPoint x="676" y="284" as="targetPoint"/>
      </mxGeometry>
    </mxCell>

    <mxCell id="eqn" value="V dA/dt = q(A&lt;sub&gt;f&lt;/sub&gt; &#8722; A) &#8722; V k&#8320; A e&lt;sup&gt;&#8722;E&#8336;/RT&lt;/sup&gt;&#10;V&#961;C&lt;sub&gt;p&lt;/sub&gt; dT/dt = q&#961;C&lt;sub&gt;p&lt;/sub&gt;(T&lt;sub&gt;f&lt;/sub&gt; &#8722; T) + (&#8722;&#916;H) V k&#8320; A e&lt;sup&gt;&#8722;E&#8336;/RT&lt;/sup&gt;&#10;Feed flowrate q is held constant, so the product flowrate equals it." style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#333333;strokeColor=#cccccc;fillColor=#f7f7f7;spacing=8;" vertex="1" parent="1">
      <mxGeometry x="100" y="620" width="620" height="76" as="geometry"/>
    </mxCell>

    <mxCell id="caveat" value="This example has &lt;b&gt;no parameter table anywhere in the paper&lt;/b&gt; &#8212; no numerical values and no units are given for q, A&lt;sub&gt;f&lt;/sub&gt;, T&lt;sub&gt;f&lt;/sub&gt;, V, k&#8320;, E&#8336;/R or &#916;H, so none are printed here.&#10;The paper contains no process schematic; this diagram is composed from its equations. Nozzle elevations are not specified &#8212; only a single feed and a single product are implied by the balances." style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#777777;strokeColor=none;fillColor=none;spacing=4;" vertex="1" parent="1">
      <mxGeometry x="100" y="704" width="960" height="46" as="geometry"/>
    </mxCell>

