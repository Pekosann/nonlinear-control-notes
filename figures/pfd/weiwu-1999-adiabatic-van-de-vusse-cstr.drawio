      <mxGeometry x="72" y="140" width="120" height="20" as="geometry"/>
    </mxCell>

    <mxCell id="prod" value="F&#160;&#160; C&lt;sub&gt;A&lt;/sub&gt;&#160;&#160; C&lt;sub&gt;B&lt;/sub&gt;&#160;&#160; T" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=classic;endFill=1;strokeColor=#000000;strokeWidth=2;fontSize=14;verticalAlign=bottom;labelBackgroundColor=#ffffff;" edge="1" parent="1">
