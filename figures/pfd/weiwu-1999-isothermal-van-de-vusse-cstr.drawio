    <mxCell id="inner" value="&lt;b&gt;Isothermal CSTR&lt;/b&gt;&lt;br&gt;V&lt;sub&gt;r&lt;/sub&gt;&lt;br&gt;C&lt;sub&gt;A&lt;/sub&gt;, C&lt;sub&gt;B&lt;/sub&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;strokeColor=none;fillColor=none;" vertex="1" parent="1">
