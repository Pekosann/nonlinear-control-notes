    <mxCell id="isonote" value="&lt;b&gt;Isothermal&lt;/b&gt; operation is &lt;b&gt;assumed&lt;/b&gt;, not achieved by any modelled&#10;hardware &#8212; the papers include no jacket, coil or heat exchanger.&#10;No pump or valve is modelled either: the dilution rate F/V&lt;sub&gt;r&lt;/sub&gt; is&#10;manipulated directly. Species C and D are formed but never tracked." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#333333;strokeColor=#cccccc;fillColor=#f7f7f7;spacing=8;" vertex="1" parent="1">
      <mxGeometry x="620" y="150" width="500" height="86" as="geometry"/>
    </mxCell>
    <mxCell id="isolead" style="edgeStyle=none;html=1;endArrow=none;strokeColor=#999999;strokeWidth=1;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="554" y="240" as="sourcePoint"/>
        <mxPoint x="616" y="212" as="targetPoint"/>
      </mxGeometry>
    </mxCell>

    <mxCell id="eqn" value="dC&lt;sub&gt;A&lt;/sub&gt;/dt = &#8722;k&#8321;C&lt;sub&gt;A&lt;/sub&gt; &#8722; k&#8323;C&lt;sub&gt;A&lt;/sub&gt;&#178; + (F/V&lt;sub&gt;r&lt;/sub&gt;)(C&lt;sub&gt;Af&lt;/sub&gt; &#8722; C&lt;sub&gt;A&lt;/sub&gt;)&#10;dC&lt;sub&gt;B&lt;/sub&gt;/dt =&#160; k&#8321;C&lt;sub&gt;A&lt;/sub&gt; &#8722; k&#8322;C&lt;sub&gt;B&lt;/sub&gt; &#8722; (F/V&lt;sub&gt;r&lt;/sub&gt;)C&lt;sub&gt;B&lt;/sub&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#333333;strokeColor=#cccccc;fillColor=#f7f7f7;spacing=8;" vertex="1" parent="1">
      <mxGeometry x="100" y="600" width="440" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="ptable" value="&lt;b&gt;Two parameter sets for the same reactor&lt;/b&gt;&lt;table cellspacing=&quot;0&quot; cellpadding=&quot;3&quot; style=&quot;margin-top:6px;border-collapse:collapse;font-size:11px&quot;&gt;&lt;tr style=&quot;border-bottom:1px solid #bbb&quot;&gt;&lt;td&gt;&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;&lt;i&gt;J. Process Control&lt;/i&gt; &lt;b&gt;9&lt;/b&gt;, 171&lt;br&gt;stable inverse control&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;&lt;i&gt;Chem. Eng. Sci.&lt;/i&gt; &lt;b&gt;54&lt;/b&gt;, 3815&lt;br&gt;adaptive control&lt;/td&gt;&lt;td&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;k&lt;sub&gt;1&lt;/sub&gt;&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;0.05&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;50&lt;/td&gt;&lt;td&gt;h&lt;sup&gt;-1&lt;/sup&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;k&lt;sub&gt;2&lt;/sub&gt;&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;0.10&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;100&lt;/td&gt;&lt;td&gt;h&lt;sup&gt;-1&lt;/sup&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;k&lt;sub&gt;3&lt;/sub&gt;&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;0.101&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;101&lt;/td&gt;&lt;td&gt;m&#179;/(kmol&#183;h)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;(F/V&lt;sub&gt;r&lt;/sub&gt;)&lt;sub&gt;s&lt;/sub&gt;&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;0.1&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;1&lt;/td&gt;&lt;td&gt;h&lt;sup&gt;-1&lt;/sup&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;C&lt;sub&gt;Af&lt;/sub&gt;&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;10&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;10&lt;/td&gt;&lt;td&gt;kmol/m&#179;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;border-top:1px solid #bbb&quot;&gt;&lt;td&gt;(C&lt;sub&gt;A&lt;/sub&gt;&lt;sup&gt;s&lt;/sup&gt;, C&lt;sub&gt;B&lt;/sub&gt;&lt;sup&gt;s&lt;/sup&gt;)&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;2.49, 0.622&lt;/td&gt;&lt;td align=&quot;center&quot;&gt;0.151, 0.075&lt;/td&gt;&lt;td&gt;kmol/m&#179;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#333333;strokeColor=#cccccc;fillColor=#f7f7f7;spacing=8;" vertex="1" parent="1">
      <mxGeometry x="560" y="580" width="560" height="212" as="geometry"/>
    </mxCell>

    <mxCell id="caveat" value="Neither paper contains a process schematic; this diagram is composed from their equations. Reactor dimensions are not specified &#8212; only the ratio F/V&lt;sub&gt;r&lt;/sub&gt; is ever used.&#10;&lt;b&gt;Correction:&lt;/b&gt; the body text of the stable-inverse-control paper prints k&#8323; = 0.010; that is a typo. Only k&#8323; = 0.101 reproduces the stated steady state (2.49, 0.622). The papers write the k&#8323; unit as (kmol&#183;h)&#8315;&#185;, which is dimensionally wrong; it must be m&#179;/(kmol&#183;h)." style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#777777;strokeColor=none;fillColor=none;spacing=4;" vertex="1" parent="1">
      <mxGeometry x="100" y="806" width="1020" height="52" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
