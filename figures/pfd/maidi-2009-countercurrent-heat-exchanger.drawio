    </mxCell>

    <mxCell id="eqn" value="&#8706;T/&#8706;t&#160;&#160; = &#8722;v &#8706;T/&#8706;z&#160;&#160; + a (T&lt;sub&gt;e&lt;/sub&gt; &#8722; T),&#160;&#160;&#160; a&#160;&#160;= 2.92 s&#8315;&#185;,&#160; T(0,t) = T&lt;sub&gt;0&lt;/sub&gt;(t)&#10;&#8706;T&lt;sub&gt;e&lt;/sub&gt;/&#8706;t = +v&lt;sub&gt;e&lt;/sub&gt; &#8706;T&lt;sub&gt;e&lt;/sub&gt;/&#8706;z + a&lt;sub&gt;e&lt;/sub&gt;(T &#8722; T&lt;sub&gt;e&lt;/sub&gt;),&#160;&#160;&#160; a&lt;sub&gt;e&lt;/sub&gt; = 5 s&#8315;&#185;,&#160;&#160;&#160; T&lt;sub&gt;e&lt;/sub&gt;(L,t) = T&lt;sub&gt;e&lt;sub&gt;L&lt;/sub&gt;&lt;/sub&gt;(t)" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#333333;strokeColor=#cccccc;fillColor=#f7f7f7;spacing=8;" vertex="1" parent="1">
      <mxGeometry x="600" y="600" width="500" height="52" as="geometry"/>
    </mxCell>

    <mxCell id="caveat" value="Only the lumped groups a and a&lt;sub&gt;e&lt;/sub&gt; are given numerically; cross-sections S, S&lt;sub&gt;e&lt;/sub&gt;, the transfer area and the individual densities, heat capacities and film coefficients are not specified in the paper, nor are any diameters.&#10;The jacket is a continuous distributed annulus &#8212; the paper defines no jacket zones. Utility is a liquid or non-condensing vapour, not condensing steam." style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#777777;strokeColor=none;fillColor=none;spacing=4;" vertex="1" parent="1">
