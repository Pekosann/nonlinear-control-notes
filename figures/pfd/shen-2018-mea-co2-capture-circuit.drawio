    <mxCell id="legend" value="&lt;b&gt;Streams&lt;/b&gt;&#160;&#160;&#160;&#9472;&#9472; gas&#160;&#160;&#160;&lt;font color=&quot;#b7791f&quot;&gt;&#9472;&#9472; rich solvent&lt;/font&gt;&#160;&#160;&#160;&lt;font color=&quot;#1f6fb2&quot;&gt;&#9472;&#9472; lean solvent / condensate / make-up&lt;/font&gt;&#160;&#160;&#160;&lt;font color=&quot;#c0392b&quot;&gt;&#9472;&#9472; heating&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;strokeColor=#cccccc;fillColor=#fafafa;spacing=8;" vertex="1" parent="1">
      <mxGeometry x="60" y="1000" width="700" height="30" as="geometry"/>
    </mxCell>

    <mxCell id="chem" value="Reactive absorption of CO&#8322; into 30 wt% aqueous MEA (exothermic, temperature bulge in the absorber); endothermic desorption in the stripper, driven by the reboiler.&#10;Both columns are &lt;b&gt;counter-current&lt;/b&gt;: gas rises, liquid falls. Rate-based two-film model; apparent species CO&#8322;, MEA, H&#8322;O with electrolyte-NRTL speciation." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#333333;strokeColor=#cccccc;fillColor=#f7f7f7;spacing=8;" vertex="1" parent="1">
      <mxGeometry x="60" y="1040" width="1000" height="52" as="geometry"/>
    </mxCell>

    <mxCell id="caveat" value="&lt;b&gt;Flue gas flow:&lt;/b&gt; the paper's Fig. 1 gives 8000 kmol/hr but its Table 2 gives 40 000 kmol/h. Only 8000 closes the mass balance (8000 &#215; 0.146 at 90 % capture leaves 7360 kmol/hr at y&lt;sub&gt;CO2&lt;/sub&gt; &#8776; 0.016, as labelled), so 8000 is used here.&#10;&lt;b&gt;Column geometry&lt;/b&gt; is taken from Fig. 1, not from the local shen2018_analysis.tex, whose table swaps the absorber height and diameter. Packing constants are never specified. All instrumentation and control loops are omitted." style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#777777;strokeColor=none;fillColor=none;spacing=4;" vertex="1" parent="1">
      <mxGeometry x="1080" y="1000" width="680" height="92" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
